{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arx",
  "version": "0.1.0",
  "identifier": "com.johnjeong.arx",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Arx",
        "width": 1540,
        "height": 980,
        "minWidth": 1160,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

