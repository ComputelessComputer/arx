{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arx",
  "version": "0.1.0",
  "identifier": "com.johnjeong.arx",
  "build": {
    "beforeDevCommand": "pnpm run dev:tauri",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Arx",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "width": 400,
        "height": 560,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
