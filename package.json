{
  "name": "arx-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @arx/desktop dev",
    "tauri": "pnpm --filter @arx/desktop tauri",
    "web": "pnpm --filter @arx/web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "pnpm --filter @arx/desktop test"
  },
  "devDependencies": {
    "turbo": "^2.8.14"
  }
}
